        reason: RISK_ACCEPTED

    WS-I011-TYPESCRIPT-00001:
      tasks/**/*.js:
        reason: RISK_ACCEPTED

    BUILTIN-401:
      src/nationalarchives/templates/fixtures.json:
        reason: FALSE_POSITIVE

    WS-I011-JAVASCRIPT-00003:
